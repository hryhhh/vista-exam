# ===== 多阶段构建 =====
# 阶段1: 构建前端
FROM node:20-alpine AS frontend-builder

WORKDIR /app

# 安装 pnpm（pnpm 11 需要 Node 22，Node 20 需用 pnpm 9）
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# 复制前端源码
COPY yf-bev2-vue/package.json yf-bev2-vue/ ./
RUN pnpm install

# 复制其余前端源码
COPY yf-bev2-vue/ ./

# 生产构建
RUN pnpm run build:pro

# 阶段2: 运行
FROM nginx:alpine

LABEL maintainer="hryhhh"
LABEL description="远见在线考试系统 - 前端Nginx镜像"

# 复制前端构建产物
COPY --from=frontend-builder /app/dist-pro /usr/share/nginx/html

# 复制自定义nginx配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
